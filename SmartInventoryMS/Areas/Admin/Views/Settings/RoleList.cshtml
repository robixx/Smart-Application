
@model List<SmartInventory.Applycation.ModelView.RoleDto>

@{
    ViewData["Title"] = "User List";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<style>
    .form-check-input:checked {
        background-color: var(--primary);
        border-color: var(--primary);
    }
    .role-icon{
        width: 60px;
        height: 60px;
        border-radius: 15px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 28px;
        color:var(--primary);
    }
    .role-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
}

.role-badge {
    background: #e4e6eb;
    padding: 3px 8px;
    border-radius: 6px;
    font-size: 12px;
    color: #333;
}
.stat-title {
    cursor: pointer;             
    padding: 2px 6px;            
    border-radius: 4px;          
    transition: background 0.2s; 
}

.stat-title:hover {
     background-color: #688c27;  
     color:white;
}

.delete-icon {
    margin-left: 5px;
    cursor: pointer;
    font-weight: bold;
    color: red;
}
</style>

<div class="dashboard-content">
    <h3 class="page-title">Role Manage</h3>
    <div class="card">
        <div class="card-body d-flex justify-content-between align-items-center">           
                <h3 class="table-title">Role Data List</h3>                     
                <button class="btn-add-new btn-sm" onclick="openModal()">
                    <i class="bi bi-plus-lg"></i>
                    Add New Role
                </button>         
        </div>       
    </div> 
    <div class="stats-grid mt-4">
        <!-- Super Admin -->
        @foreach(var item in Model)
        {
             <div class="stat-card">
                <div class="d-flex align-items-center gap-2 mb-2">
                    <div class="role-icon">
                        <i class="bi bi-person-badge"></i>
                    </div>
                    <div class="stat-title" onclick="assignUser('@item.RoleName', @item.RoleId)">@item.RoleName</div>
                </div>
                <div class="stat-label mb-2">Person Name</div>

                <div class="role-tags">
                   @if (item.userlist != null && item.userlist.Any())
                    {
                        foreach (var usern in item.userlist)
                        {
                            <span class="role-badge">
                                @(usern.UserName ?? "Unknown")
                                <i class="delete-icon"
                                   onclick="deleteBadge(@usern.UserId, @item.RoleId)">×</i>
                            </span>
                        }
                    }
                    else
                    {
                        <span class="text-muted">No users assigned</span>
                    }
                </div>
            </div>
        }
       
    </div>
</div>

<div class="modal fade" id="exampleModal" tabindex="-1" aria-labelledby="modalTitle" aria-hidden="true">
    <div class="modal-dialog modal-dialog-top">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalTitle">Add New Role</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="userForm">
                    
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-add-new" onclick="SaveRole()">Save Role</button>
            </div>
        </div>
    </div>
</div>

<script>
       function openModal() {
            const form = document.getElementById('userForm');
            form.innerHTML = '';             
            const roleFields = document.createElement('div');
                roleFields.id = 'roleFields';
                roleFields.classList.add('modal-section');
                roleFields.innerHTML = `
                    <input type="hidden" id="roleId">
                    <div class="form-group mb-3">
                        <label class="form-label" for="userRole">Role Name</label>
                        <input type="text" class="form-control" id="userRole" placeholder="Enter role name" required>
                    </div>
                    <div class="form-group mb-3">
                        <div class="form-check">
                            <input type="checkbox" class="form-check-input" id="isActive" checked>
                            <label class="form-check-label" for="isActive">Active</label>
                        </div>
                    </div>
                `;
            form.appendChild(roleFields);

            document.getElementById('modalTitle').innerText = "Add New Role";

            $('#exampleModal').modal('show'); 
        }

        function assignUser(data, id) {
            const form = document.getElementById('userForm');
            form.innerHTML = '';             
            const assignFields = document.createElement('div');
            assignFields.id = 'assignFields';
            assignFields.classList.add('modal-section');
            assignFields.innerHTML = `
                <label class="form-label" for="userName">User </label>
                <select class="form-control">
                    <option> Select User </option>
                    <option>John</option>
                    <option>Rahim</option>
                    <option>Karim</option>
                </select>
            `;
            form.appendChild(assignFields);

            document.getElementById('modalTitle').innerText = data;
            $('#exampleModal').modal('show');
        }


        function deleteBadge(el) {
            const badge = el.parentElement; // get the <span>
            const badgeName = badge.textContent.replace('×', '').trim(); // get badge text
            const confirmDelete = confirm(`Are you sure you want to delete "${badgeName}"?`);

            if (confirmDelete) {
                badge.remove(); // remove badge from DOM
            }
        }

        function SaveRole() {
            const roleid = document.getElementById('roleId').value;
            const userRole = document.getElementById('userRole').value;
            const isActive = document.getElementById('isActive').checked;

            // Validation (optional but recommended)
            if (!userRole) {
                showToast("Role name is required", "danger");
                return;
            }

            const roleDto = {
                RoleId: parseInt(roleid) || 0,
                RoleName: userRole.trim(),
                IsActive: isActive ? 1 : 0
            };

            fetch('/Admin/Settings/SaveRole', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify(roleDto)
            })
            .then(response => {
                if (!response.ok) {
                    throw new Error("HTTP error " + response.status);
                }
                return response.json();
            })
            .then(data => {
                debugger;
                if (data.status) {
                    showToast(data.message, "success");                 

                    setTimeout(() => {
                        window.location.reload();
                    }, 2000);
                } else {
                    showToast(data.message, "danger");
                }
            })
            .catch(err => {
               debugger;
                showToast('Unexpected error occurred.', "danger");
            });
        }
</script>