
@model List<SmartInventory.Applycation.ModelView.RoleDto>

@{
    ViewData["Title"] = "User List";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<style>
    .form-check-input:checked {
        background-color: var(--primary);
        border-color: var(--primary);
    }
    .role-icon{
        width: 60px;
        height: 60px;
        border-radius: 15px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 28px;
        color:var(--primary);
    }
    .role-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
}

.role-badge {
    background: #e4e6eb;
    padding: 3px 8px;
    border-radius: 6px;
    font-size: 12px;
    color: #333;
}
.stat-title {
    cursor: pointer;             
    padding: 2px 6px;            
    border-radius: 4px;          
    transition: background 0.2s; 
}

.stat-title:hover {
     background-color: #688c27;  
     color:white;
}

.delete-icon {
    margin-left: 5px;
    cursor: pointer;
    font-weight: bold;
    color: red;
}

.action-menu {
    position: absolute;
    top: 10px;
    right: 10px;
}

.action-icon {
    cursor: pointer;
    padding: 6px;
    border-radius: 30%;
    transition: 0.3s;
}

.action-icon:hover {
    background: #f1f1f1;
}

/* Dropdown */
.action-dropdown {
    position: absolute;
    top: 30px;
    right: 0;
    background: #fff;
    border-radius: 10px;
    min-width: 120px;
    box-shadow: 0 8px 20px rgba(0,0,0,0.1);
    opacity: 0;
    transform: translateY(10px);
    pointer-events: none;
    transition: all 0.25s ease;
    z-index: 100;
}

/* Show on hover */
.action-menu:hover .action-dropdown {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
}

/* Items */
.action-item {
    padding: 10px 12px;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 8px;
    transition: 0.2s;
    font-size: 14px;
}

.action-item:hover {
    background: #f8f9fa;
}

.action-item.text-danger:hover {
    background: #ffeaea;
}
</style>

<div class="dashboard-content">
    <h3 class="page-title">Role Manage</h3>
    <div class="card">
        <div class="card-body d-flex justify-content-between align-items-center">           
                <h3 class="table-title">Role Data List</h3>                     
                <button class="btn-add-new btn-sm" onclick="openModal()">
                    <i class="bi bi-plus-lg"></i>
                    Add New Role
                </button>         
        </div>       
    </div> 
    <div class="stats-grid mt-4">
       
        @foreach (var item in Model)
        {
            <div class="stat-card position-relative">

                <!-- Top Right Menu -->
                <div class="dropdown position-absolute top-0 end-0 m-2">
                    <div class="action-menu">
                        <i class="bi bi-three-dots-vertical action-icon"></i>

                        <div class="action-dropdown">
                            <div class="action-item"
                                 onclick="openModal({ RoleId: @item.RoleId, RoleName: '@item.RoleName', IsActive: @item.IsActive })">
                                <i class="bi bi-pencil-square"></i> Edit
                            </div>

                            <div class="action-item text-danger"
                                 onclick="deleteRole(@item.RoleId)">
                                <i class="bi bi-trash"></i> Delete
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Card Content -->
                <div class="d-flex align-items-center gap-2 mb-2">
                    <div class="role-icon">
                        <i class="bi bi-person-badge"></i>
                    </div>

                    <div class="stat-title"
                         onclick="assignUser('@item.RoleName', @item.RoleId)">
                        @item.RoleName
                    </div>
                </div>

                <div class="stat-label mb-2">Person Name</div>

                <div class="role-tags">
                    @if (item.userlist != null && item.userlist.Any())
                    {
                        foreach (var usern in item.userlist)
                        {
                            <span class="role-badge">
                                @(usern.UserName ?? "Unknown")
                                <i class="delete-icon"
                                   onclick="deleteBadge(@usern.UserId, @item.RoleId)">×</i>
                            </span>
                        }
                        
                    }
                    else
                    {
                        <span class="text-muted">No users assigned</span>
                    }
                </div>
            </div>
        }
       
    </div>
</div>

<div class="modal fade" id="exampleModal" tabindex="-1" aria-labelledby="modalTitle" aria-hidden="true">
    <div class="modal-dialog modal-dialog-top">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalTitle">Add New Role</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="userForm">
                    
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-add-new" onclick="SaveRole()">Save Role</button>
            </div>
        </div>
    </div>
</div>

<script src="~/js/sweetalrt.js"></script>
<script>
       function openModal(role = null) {
            const form = document.getElementById('userForm');
            debugger;
            form.innerHTML = '';             
            const roleFields = document.createElement('div');
                roleFields.id = 'roleFields';
                roleFields.classList.add('modal-section');
                  // If role object is passed → fill values (Edit)
                const roleId = role ? role.RoleId : '';
                const roleName = role ? role.RoleName : '';
                const isActive = role ? role.IsActive === 1 : true;
                roleFields.innerHTML = `
                    <input type="hidden" id="roleId" value="${roleId}">
                    <div class="form-group mb-3">
                        <label class="form-label" for="userRole">Role Name</label>
                        <input type="text" class="form-control" id="userRole" placeholder="Enter role name" value="${roleName}" required>
                    </div>
                    <div class="form-group mb-3">
                        <div class="form-check">
                            <input type="checkbox" class="form-check-input" id="isActive" ${isActive ? 'checked' : ''}>
                            <label class="form-check-label" for="isActive">Active</label>
                        </div>
                    </div>
                `;
            form.appendChild(roleFields);

             document.getElementById('modalTitle').innerText = role ? "Edit Role" : "Add New Role";

            $('#exampleModal').modal('show'); 
        }

        function assignUser(data, id) {
            const form = document.getElementById('userForm');
            form.innerHTML = '';             
            const assignFields = document.createElement('div');
            assignFields.id = 'assignFields';
            assignFields.classList.add('modal-section');
            assignFields.innerHTML = `
                <label class="form-label" for="userName">User </label>
                <select class="form-control">
                    <option> Select User </option>
                    <option>John</option>
                    <option>Rahim</option>
                    <option>Karim</option>
                </select>
            `;
            form.appendChild(assignFields);

            document.getElementById('modalTitle').innerText = data;
            $('#exampleModal').modal('show');
        }


        function deleteBadge(el) {
            const badge = el.parentElement; // get the <span>
            const badgeName = badge.textContent.replace('×', '').trim(); // get badge text
            const confirmDelete = confirm(`Are you sure you want to delete "${badgeName}"?`);

            if (confirmDelete) {
                badge.remove(); // remove badge from DOM
            }
        }

        function SaveRole() {
            const roleid = document.getElementById('roleId').value;
            const userRole = document.getElementById('userRole').value;
            const isActive = document.getElementById('isActive').checked;

            // Validation (optional but recommended)
            if (!userRole) {
                showToast("Role name is required", "danger");
                return;
            }

            const roleDto = {
                RoleId: parseInt(roleid) || 0,
                RoleName: userRole.trim(),
                IsActive: isActive ? 1 : 0
            };

            fetch('/Admin/Settings/SaveRole', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify(roleDto)
            })
            .then(response => {
                if (!response.ok) {
                    throw new Error("HTTP error " + response.status);
                }
                return response.json();
            })
            .then(data => {
                debugger;
                if (data.status) {
                     $('#exampleModal').modal('hide'); 
                    showToast(data.message, "success");                 

                    setTimeout(() => {
                        window.location.reload();
                    }, 2000);
                } else {
                    showToast(data.message, "danger");
                }
            })
            .catch(err => {
               
                showToast('Unexpected error occurred.', "danger");
            });
        }

        function deleteRole(id) {
          
             confirmAction('Are you want to Delete this Role?', 'This action cannot be undone!', function () {
        
                fetch(`/Admin/Settings/DeleteRole/${id}`, {
                    method: 'POST'
                })
                .then(res => res.json())
                .then(data => {
                    if (data.status) {
                        showToast(data.message, "success");
                       
                        setTimeout(()=>{
                            window.location.reload();
                        },2000)                       
                        

                    } else {
                        showToast(data.message, "danger");
                    }
                });

            });
        }
       

</script>