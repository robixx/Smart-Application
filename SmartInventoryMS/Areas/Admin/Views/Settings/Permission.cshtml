@{
    ViewData["Title"] = "Role Wise Permission";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<style>
    .form-check-input:checked {
        background-color: var(--primary);
        border-color: var(--primary);
    }
    .role-icon{
        width: 60px;
        height: 60px;
        border-radius: 15px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 28px;
        color:var(--primary);
    }
    .role-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
}

.role-badge {
    background: #e4e6eb;
    padding: 3px 8px;
    border-radius: 6px;
    font-size: 12px;
    color: #333;
}
.stat-title {
    cursor: pointer;             
    padding: 2px 6px;            
    border-radius: 4px;          
    transition: background 0.2s; 
}

.stat-title:hover {
     background-color: #688c27;  
     color:white;
}

.delete-icon {
    margin-left: 5px;
    cursor: pointer;
    font-weight: bold;
    color: red;
}
.role-card {
            border: none;
            border-radius: 15px;
            background: white;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            transition: all 0.3s ease;
            overflow: hidden;
            margin-bottom: 25px;
        }

        .role-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 20px 40px rgba(0,0,0,0.15);
        }

        /* Card Header - Role Name Only */
        .card-header-custom {
            padding: 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .role-title {
            font-size: 1.3rem;
            font-weight: 700;
            color: #678b27;
            margin: 0;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .delete-btn {
            background: rgba(255,255,255,0.2);
            border: none;
            color: white;
            width: 35px;
            height: 35px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .delete-btn:hover {
            background: #dc3545;
            transform: rotate(90deg);
        }

        /* Card Body - Page List */
        .card-body-custom {
            padding: 0;
        }

        .page-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 15px 20px;
            border-bottom: 1px solid #e9ecef;
            transition: all 0.3s ease;
        }

        .page-item:hover {
            background: #f8f9fa;
        }

        .page-item:last-child {
            border-bottom: none;
        }

        .page-info {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .page-icon {
            width: 38px;
            height: 38px;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1rem;
        }

        .page-name {
            font-size: 0.95rem;
            font-weight: 600;
            color: #2d3748;
            margin: 0;
            text-transform: capitalize;
        }

        .page-path {
            font-size: 0.75rem;
            color: #6c757d;
            font-family: 'Courier New', monospace;
        }

        /* Badge List */
        .badge-list {
            display: flex;
            flex-wrap: wrap;
            gap: 5px;
            justify-content: flex-end;
        }

        .page-badge {
            padding: 3px 8px;
            border-radius: 12px;
            font-size: 0.65rem;
            font-weight: 500;
        }

        /* Role Colors */
       /*  .card-admin .card-header-custom { background: #43600e; } */
        .card-admin .page-icon { background: rgba(102, 126, 234, 0.1); color: #667eea; }
        .card-admin .badge-view { background: #dbeafe; color: #2563eb; }
        .card-admin .badge-add { background: #d1fae5; color: #059669; }
        .card-admin .badge-edit { background: #fef3c7; color: #d97706; }
        .card-admin .badge-delete { background: #fee2e2; color: #dc2626; }

        .card-manager .card-header-custom { background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%); }
        .card-manager .page-icon { background: rgba(240, 147, 251, 0.1); color: #f093fb; }
        .card-manager .badge-view { background: #fce7f3; color: #db2777; }
        .card-manager .badge-add { background: #d1fae5; color: #059669; }
        .card-manager .badge-edit { background: #fef3c7; color: #d97706; }

        .card-user .card-header-custom { background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%); }
        .card-user .page-icon { background: rgba(79, 172, 254, 0.1); color: #4facfe; }
        .card-user .badge-view { background: #dbeafe; color: #2563eb; }

        .card-sales .card-header-custom { background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%); }
        .card-sales .page-icon { background: rgba(67, 233, 123, 0.1); color: #43e97b; }
        .card-sales .badge-view { background: #d1fae5; color: #059669; }
        .card-sales .badge-add { background: #dbeafe; color: #2563eb; }
        .card-sales .badge-edit { background: #fef3c7; color: #d97706; }

        /* Page Count Badge in Header */
        .page-count {
            background: rgba(255,255,255,0.2);
            color: white;
            padding: 4px 12px;
            border-radius: 15px;
            font-size: 0.8rem;
            margin-left: 10px;
        }
</style>

