
@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}


<div class="dashboard-content">
    <h1 class="page-title">Dashboard Overview</h1>

    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-icon">
                <i class="bi bi-currency-dollar"></i>
            </div>
            <div class="stat-value">$45,250</div>
            <div class="stat-label">Total Revenue</div>
            <span class="stat-change positive">
                <i class="bi bi-arrow-up-circle"></i> +12.5%
            </span>
        </div>
        <div class="stat-card">
            <div class="stat-icon">
                <i class="bi bi-people"></i>
            </div>
            <div class="stat-value">2,450</div>
            <div class="stat-label">Total Users</div>
            <span class="stat-change positive">
                <i class="bi bi-arrow-up-circle"></i> +8.2%
            </span>
        </div>
        <div class="stat-card">
            <div class="stat-icon">
                <i class="bi bi-cart-check"></i>
            </div>
            <div class="stat-value">1,280</div>
            <div class="stat-label">Total Orders</div>
            <span class="stat-change negative">
                <i class="bi bi-arrow-down-circle"></i> -3.1%
            </span>
        </div>
        <div class="stat-card">
            <div class="stat-icon">
                <i class="bi bi-graph-up"></i>
            </div>
            <div class="stat-value">89.5%</div>
            <div class="stat-label">Conversion Rate</div>
            <span class="stat-change positive">
                <i class="bi bi-arrow-up-circle"></i> +4.3%
            </span>
        </div>
    </div>

    <div class="charts-row">
        <div class="chart-card">
            <div class="chart-header">
                <h3 class="chart-title">Revenue Analytics</h3>
                <button class="btn btn-outline-secondary btn-sm">
                    <i class="bi bi-download"></i> Export
                </button>
            </div>
            <div class="chart-placeholder">
                <i class="bi bi-bar-chart-line" style="font-size: 48px;"></i>
                <span>Chart Component Placeholder</span>
            </div>
        </div>
        <div class="chart-card">
            <div class="chart-header">
                <h3 class="chart-title">Traffic Sources</h3>
            </div>
            <div class="chart-placeholder" style="height: 300px;">
                <i class="bi bi-pie-chart" style="font-size: 48px;"></i>
                <span>Pie Chart Placeholder</span>
            </div>
        </div>
    </div>

    <div class="table-card">
        <div class="chart-header">
            <h3 class="chart-title">Recent Orders</h3>
            <button class="btn btn-sm" style="background: var(--primary); color: white; font-weight: 600;">
                View All
            </button>
        </div>
        <div class="table-responsive">
            <table id="ordersTable" class="table table-striped table-bordered">
