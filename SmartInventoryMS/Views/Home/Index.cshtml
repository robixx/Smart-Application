@{
    ViewData["Title"] = "Login Page";
}
<div class="login-wrapper">
    <div class="login-container">
        <div class="login-header">
            <div class="brand-logo">
                <i class="bi bi-boxes"></i>
            </div>
            <h1 class="login-title">Welcome Back</h1>
            <p class="login-subtitle">Sign in to continue to LemonAdmin</p>
        </div>

        <div class="login-body">
            <form id="loginForm" onsubmit="handleLogin(event)">
                <div class="form-group">
                    <label class="form-label">Email Address</label>
                    <div class="input-group">
                        <input type="email" class="form-control" placeholder="Enter your email" required>
                        <i class="bi bi-envelope-fill input-group-icon"></i>
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label">Password</label>
                    <div class="input-group">
                        <input type="password" class="form-control" id="passwordInput" placeholder="Enter your password" required>
                        <i class="bi bi-lock-fill input-group-icon"></i>
                        <button type="button" class="password-toggle" onclick="togglePassword()">
                            <i class="bi bi-eye-fill" id="toggleIcon"></i>
                        </button>
                    </div>
                </div>

                <div class="form-options">
                    <div class="remember-me">
                        <input type="checkbox" id="remember">
                        <label for="remember">Remember me</label>
                    </div>
                    <a href="#" class="forgot-password">Forgot password?</a>
                </div>

                <button type="submit" class="btn-login">
                    <i class="bi bi-box-arrow-in-right me-2"></i> Sign In
                </button>
            </form>

            <div class="divider d-none">
                <span>or continue with</span>
            </div>

            <div class="social-login d-none">
                <button type="button" class="social-btn" title="Google">
                    <i class="bi bi-google"></i>
                </button>
                <button type="button" class="social-btn" title="Facebook">
                    <i class="bi bi-facebook"></i>
                </button>
                <button type="button" class="social-btn" title="Twitter">
                    <i class="bi bi-twitter-x"></i>
                </button>
                <button type="button" class="social-btn" title="LinkedIn">
                    <i class="bi bi-linkedin"></i>
                </button>
            </div>
        </div>

        <div class="login-footer">
            <p>Don't have an account? <a href="#">Sign up</a></p>
        </div>
    </div>
</div>